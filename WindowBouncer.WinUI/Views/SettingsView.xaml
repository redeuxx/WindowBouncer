<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WindowBouncer.Views.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:WindowBouncer.ViewModels"
    xmlns:settings="using:WindowBouncer.Settings">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <Grid.Resources>
            <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Margin"     Value="0,12,0,4"/>
                <Setter Property="FontSize"   Value="13"/>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <NavigationView
            Grid.Row="0"
            x:Name="Nav"
            PaneDisplayMode="Top"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            SelectionChanged="Nav_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Tag="general"  Content="General"     IsSelected="True"/>
                <NavigationViewItem Tag="hotkeys"  Content="Hotkeys"/>
                <NavigationViewItem Tag="exclude"  Content="Exclude List"/>
            </NavigationView.MenuItems>

            <Grid Padding="20">

                <!-- GENERAL -->
                <StackPanel x:Name="GeneralPane" Spacing="2">
                    <TextBlock Text="STARTUP" Style="{StaticResource SectionHeaderStyle}"/>
                    <CheckBox Content="Start with Windows"
                              IsChecked="{x:Bind ViewModel.StartWithWindows, Mode=TwoWay}"/>
                    <CheckBox Content="Start minimized to tray"
                              IsChecked="{x:Bind ViewModel.StartMinimized, Mode=TwoWay}"/>
                    <CheckBox Content="Run as administrator (no UAC prompt)"
                              IsChecked="{x:Bind ViewModel.RunAsAdmin, Mode=TwoWay}"/>
                    <TextBlock Text="Registers a scheduled task that runs the app elevated. Requires one-time UAC approval."
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Margin="28,0,0,4"
                               TextWrapping="Wrap"/>

                    <TextBlock Text="BEHAVIOR" Style="{StaticResource SectionHeaderStyle}"/>
                    <CheckBox Content="Minimize to tray when window is closed"
                              IsChecked="{x:Bind ViewModel.CloseToTray, Mode=TwoWay}"/>

                    <TextBlock Text="APPEARANCE" Style="{StaticResource SectionHeaderStyle}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Theme:" VerticalAlignment="Center"/>
                        <ComboBox ItemsSource="{x:Bind ViewModel.Themes}"
                                  SelectedItem="{x:Bind ViewModel.Theme, Mode=TwoWay}"
                                  Width="160"/>
                    </StackPanel>
                </StackPanel>

                <!-- HOTKEYS -->
                <StackPanel x:Name="HotkeysPane" Spacing="2" Visibility="Collapsed">
                    <TextBlock Text="CLOSE ALL WINDOWS" Style="{StaticResource SectionHeaderStyle}"/>

                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 x:Name="CloseAllBox"
                                 IsReadOnly="True"
                                 Text="{x:Bind ViewModel.HotKeyCloseAll.DisplayText, Mode=OneWay}"
                                 PreviewKeyDown="HotkeyBox_PreviewKeyDown"/>

                        <Button Grid.Column="1"
                                Width="120"
                                Content="{x:Bind ViewModel.HotKeyCloseAll.CaptureButtonLabel, Mode=OneWay}"
                                Click="SetHotkey_Click"/>
                        <Button Grid.Column="2"
                                Width="60"
                                Content="Clear"
                                Command="{x:Bind ViewModel.HotKeyCloseAll.ClearCommand}"/>
                    </Grid>

                    <TextBlock Margin="0,12,0,0"
                               TextWrapping="Wrap"
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Text="Click 'Set', then press your desired key combination. At least one modifier (Ctrl, Alt, Shift, or Win) is recommended."/>
                </StackPanel>

                <!-- EXCLUDE -->
                <Grid x:Name="ExcludePane" Visibility="Collapsed" RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="EXCLUDED PROCESS NAMES" Style="{StaticResource SectionHeaderStyle}"/>

                    <Grid Grid.Row="1" RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ListView Grid.Row="0"
                                  ItemsSource="{x:Bind ViewModel.ExcludedProcessNames}"
                                  SelectedItem="{x:Bind ViewModel.SelectedProcess, Mode=TwoWay}"
                                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                  BorderThickness="1"/>
                        <Grid Grid.Row="1" ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{x:Bind ViewModel.NewProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="Add"    Command="{x:Bind ViewModel.AddProcessCommand}"/>
                            <Button Grid.Column="2" Content="Remove" Command="{x:Bind ViewModel.RemoveProcessCommand}"/>
                        </Grid>
                    </Grid>

                    <TextBlock Grid.Row="2" Text="EXCLUDED TITLE PATTERNS (substring match)" Style="{StaticResource SectionHeaderStyle}"/>

                    <Grid Grid.Row="3" RowSpacing="6">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <ListView Grid.Row="0"
                                  ItemsSource="{x:Bind ViewModel.ExcludedTitlePatterns}"
                                  SelectedItem="{x:Bind ViewModel.SelectedTitle, Mode=TwoWay}"
                                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                  BorderThickness="1"/>
                        <Grid Grid.Row="1" ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0"
                                     Text="{x:Bind ViewModel.NewTitlePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="1" Content="Add"    Command="{x:Bind ViewModel.AddTitleCommand}"/>
                            <Button Grid.Column="2" Content="Remove" Command="{x:Bind ViewModel.RemoveTitleCommand}"/>
                        </Grid>
                    </Grid>
                </Grid>

            </Grid>
        </NavigationView>

        <Grid Grid.Row="1" Padding="16,8" ColumnSpacing="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Save"   Width="80" Command="{x:Bind ViewModel.SaveCommand}"   Style="{ThemeResource AccentButtonStyle}"/>
            <Button Grid.Column="2" Content="Cancel" Width="80" Command="{x:Bind ViewModel.CancelCommand}"/>
        </Grid>
    </Grid>
</UserControl>

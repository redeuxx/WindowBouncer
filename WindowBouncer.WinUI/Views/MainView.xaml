<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WindowBouncer.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:WindowBouncer.ViewModels">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

        <Grid.Resources>
            <Style x:Key="ToolbarButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="10,6"/>
                <Setter Property="CornerRadius" Value="3"/>
            </Style>

            <Style x:Key="RowCloseButtonStyle" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Width" Value="24"/>
                <Setter Property="Height" Value="24"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="HorizontalContentAlignment" Value="Center"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="ToolTipService.ToolTip" Value="Close this window"/>
            </Style>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP TOOLBAR -->
        <Border Grid.Row="0"
                Padding="6,4"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="2">
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Command="{x:Bind ViewModel.CloseAllCommand}"
                        ToolTipService.ToolTip="Close all listed windows">
                    <TextBlock Text="Close All" FontWeight="SemiBold"/>
                </Button>
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Command="{x:Bind ViewModel.CloseSelectedCommand}"
                        ToolTipService.ToolTip="Close checked windows"
                        Content="Close Selected"/>
                <AppBarSeparator/>
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Command="{x:Bind ViewModel.RefreshCommand}"
                        ToolTipService.ToolTip="Refresh window list"
                        Content="Refresh"/>
                <AppBarSeparator/>
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Click="Settings_Click"
                        ToolTipService.ToolTip="Open settings"
                        Content="Settings"/>
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Click="About_Click"
                        ToolTipService.ToolTip="About WindowBouncer"
                        Content="About"/>
                <AppBarSeparator/>
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Click="HideToTray_Click"
                        ToolTipService.ToolTip="Hide to system tray"
                        Content="Minimize to Tray"/>
                <Button Style="{StaticResource ToolbarButtonStyle}"
                        Click="Exit_Click"
                        ToolTipService.ToolTip="Exit WindowBouncer"
                        Content="Exit"/>
            </StackPanel>
        </Border>

        <!-- SEARCH BAR -->
        <Grid Grid.Row="1"
              Padding="8,6"
              ColumnSpacing="6"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     x:Name="SearchBox"
                     PlaceholderText="Filter by title or process..."
                     Text="{x:Bind ViewModel.FilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

            <Button Grid.Column="1"
                    Content="All"
                    Padding="10,4"
                    Command="{x:Bind ViewModel.SelectAllCommand}"
                    ToolTipService.ToolTip="Select all"/>
            <Button Grid.Column="2"
                    Content="None"
                    Padding="10,4"
                    Command="{x:Bind ViewModel.SelectNoneCommand}"
                    ToolTipService.ToolTip="Deselect all"/>
        </Grid>

        <!-- COLUMN HEADER -->
        <Grid Grid.Row="2"
              Padding="8,6"
              ColumnSpacing="8"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="70"/>
                <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>

            <CheckBox x:Name="SelectAllHeader"
                      Grid.Column="0"
                      MinWidth="0" MinHeight="0"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Click="SelectAllHeader_Click"
                      ToolTipService.ToolTip="Toggle all"/>

            <TextBlock Grid.Column="2" Text="Window Title" FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="3" Text="Process"      FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="4" Text="PID"          FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
        </Grid>

        <!-- WINDOW LIST -->
        <ListView Grid.Row="3"
                  x:Name="WindowList"
                  ItemsSource="{x:Bind ViewModel.FilteredWindows, Mode=OneWay}"
                  SelectionMode="Single"
                  IsItemClickEnabled="False">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="MinHeight" Value="0"/>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="vm:WindowItemViewModel">
                    <Grid Padding="8,4" ColumnSpacing="8"
                          Background="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToSelectionBrush}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="24"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="70"/>
                            <ColumnDefinition Width="40"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox Grid.Column="0"
                                  IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  MinWidth="0" MinHeight="0"/>

                        <Image  Grid.Column="1"
                                Source="{x:Bind ProcessIcon, Mode=OneWay}"
                                Width="16" Height="16"
                                VerticalAlignment="Center"/>

                        <TextBlock Grid.Column="2"
                                   Text="{x:Bind Title}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTipService.ToolTip="{x:Bind Title}"
                                   VerticalAlignment="Center"
                                   Opacity="{x:Bind IsClosing, Mode=OneWay, Converter={StaticResource BoolToOpacity}}"/>

                        <TextBlock Grid.Column="3"
                                   Text="{x:Bind ProcessName}"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center"
                                   Opacity="{x:Bind IsClosing, Mode=OneWay, Converter={StaticResource BoolToOpacity}}"/>

                        <TextBlock Grid.Column="4"
                                   Text="{x:Bind ProcessId}"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Opacity="{x:Bind IsClosing, Mode=OneWay, Converter={StaticResource BoolToOpacity}}"/>

                        <Button Grid.Column="5"
                                Style="{StaticResource RowCloseButtonStyle}"
                                Command="{x:Bind CloseCommand}"
                                IsEnabled="{x:Bind IsClosing, Mode=OneWay, Converter={StaticResource InverseBool}}"
                                Content="&#x2715;"/>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!-- STATUS BAR -->
        <Grid Grid.Row="4"
              Padding="8,4"
              ColumnSpacing="8"
              Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" VerticalAlignment="Center">
                <Run Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}"/>
                <Run Text=" windows"/>
            </TextBlock>
            <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                <Run Text="{x:Bind ViewModel.SelectedCount, Mode=OneWay}"/>
                <Run Text=" selected"/>
            </TextBlock>
            <ProgressBar Grid.Column="3"
                         Width="100" Height="6"
                         IsIndeterminate="{x:Bind ViewModel.IsBusy, Mode=OneWay}"
                         Visibility="{x:Bind ViewModel.IsBusy, Mode=OneWay, Converter={StaticResource BoolToVisibility}}"/>
        </Grid>

    </Grid>
</UserControl>
